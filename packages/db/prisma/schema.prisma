// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @unique @default(uuid())
  name      String
  password  String   @default("")
  email     String   @unique
  avatar    String?
  rooms     Room[]
  elements  Elements[]
  createdAt DateTime @default(now())
  refreshToken String? @default("")
}

model Room {
  id        Int      @unique
  createdAt DateTime @default(now())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  elements  Elements[]
}

model Elements {
  id                 String     @unique 
  type               String
  edgeStyle          String?
  boundTextElementId String?
  points             Json?
  startArrowHead     String?
  endArrowHead       String?
  startBinding       Json?
  endBinding         Json?
  simulatePressure   Boolean?
  pressures          Float[]  @default([])
  text               String?
  fontSize           Int?
  fontFamily         String?
  textAlign          String?
  verticalAlign      String?
  fontWeight         String?
  lineHeight         Float?
  isEditing          Boolean?
  autoResize         Boolean?
  originalText       String?
  containerId        String?
  x                  Float
  y                  Int
  width              Float
  height             Float
  angle              Float
  strokeColor        String
  backgroundColor    String
  fillStyle          String
  strokeStyle        String
  strokeWidth        Int      @default(2)
  opacity            Float
  roughness          Float
  isDeleted          Boolean
  seed               Int
  version            Int
  createdAt          DateTime
  updatedAt          DateTime
  isLocked           Boolean
  roomId             Int
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  room               Room      @relation(fields: [roomId], references: [id])
}
